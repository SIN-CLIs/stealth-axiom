{
  "schema_version": "1.0",
  "description": "SIN-Axiom: Adaptive Model Router + Adapter Registry + Cache Layer",
  "tools": [
    {
      "name": "axiom-route",
      "description": "Routet Task-Type zum optimalen Modell (Micro/Mid/Heavy + Failure-Escalation).",
      "params": [
        {
          "name": "task_type",
          "type": "string",
          "description": "Task-Type: classify_element, pick_answer, verify_state, classify_page, ocr_image, solve_math, analyze_new_provider",
          "required": true
        },
        {
          "name": "context",
          "type": "string",
          "description": "Optional: complexity=high, cache_friendly=true, min_confidence=0.8"
        }
      ],
      "command": [
        "python3",
        "-c",
        "import sys; sys.path.insert(0,'/Users/jeremy/dev/stealth-axiom'); from stealth_axiom.router import AxiomRouter; r=AxiomRouter(); ctx={} if len(sys.argv)<3 else dict(x.split('=') for x in sys.argv[2].split(',')); cfg=r.route(sys.argv[1], ctx); print(cfg['name'])",
        "{task_type}",
        "{context}"
      ]
    },
    {
      "name": "axiom-stats",
      "description": "Zeigt Router-Stats: micro/mid/heavy Verteilung, estimated_cost, savings.",
      "params": [],
      "command": [
        "python3",
        "-c",
        "import sys; sys.path.insert(0,'/Users/jeremy/dev/stealth-axiom'); from stealth_axiom.router import AxiomRouter; import json; r=AxiomRouter(); print(json.dumps(r.get_stats(), indent=2))"
      ]
    },
    {
      "name": "axiom-list-adapters",
      "description": "Listet alle LoRA-Adapter aus dem Adapter-Registry mit Status.",
      "params": [],
      "command": [
        "python3",
        "-c",
        "import sys; sys.path.insert(0,'/Users/jeremy/dev/stealth-axiom'); from stealth_axiom.adapter_registry import AdapterRegistry; import json; r=AdapterRegistry(); print(json.dumps(r.list_adapters(), indent=2))"
      ]
    },
    {
      "name": "axiom-best-adapter",
      "description": "Findet den besten Adapter f\u00fcr einen Task-Hint.",
      "params": [
        {
          "name": "task_hint",
          "type": "string",
          "description": "Task-Beschreibung, z.B. 'classify element in survey page'",
          "required": true
        }
      ],
      "command": [
        "python3",
        "-c",
        "import sys; sys.path.insert(0,'/Users/jeremy/dev/stealth-axiom'); from stealth_axiom.adapter_registry import AdapterRegistry; import json; r=AdapterRegistry(); best=r.best_for_task(sys.argv[1] if len(sys.argv)>1 else ''); print(json.dumps(best, indent=2) if best else 'No adapter found')",
        "{task_hint}"
      ]
    },
    {
      "name": "cache-status",
      "description": "Zeigt Semantic-Cache-Stats: hit_rate, cached_entries, hot_entries.",
      "params": [],
      "command": [
        "/Users/jeremy/dev/stealth-cache/opencode_helper.sh",
        "--status"
      ]
    },
    {
      "name": "cache-query",
      "description": "Pr\u00fcft ob Intent/Screenshot bereits gecacht ist.",
      "params": [
        {
          "name": "intent_text",
          "type": "string",
          "description": "Fehlerbeschreibung oder Intent-Text",
          "required": true
        }
      ],
      "command": [
        "/Users/jeremy/dev/stealth-cache/opencode_helper.sh",
        "--query",
        "{intent_text}"
      ]
    },
    {
      "name": "sota-complexity",
      "description": "Sch\u00e4tzt Prompt-Komplexit\u00e4t: micro (\u226480chars, classify_element)|mid (\u2264300)|heavy (alles andere).",
      "params": [
        {
          "name": "prompt",
          "type": "string",
          "description": "Prompt-Text zum Sch\u00e4tzen",
          "required": true
        }
      ],
      "command": [
        "python3",
        "-c",
        "import sys; sys.path.insert(0,'/Users/jeremy/dev/stealth-cost'); from stealth_cost import get_optimizer; print(get_optimizer().estimate_complexity(sys.argv[1] if len(sys.argv)>1 else '', ''))",
        "{prompt}"
      ]
    },
    {
      "name": "sota-best-model",
      "description": "Gibt bestes Fireworks-Modell f\u00fcr Komplexit\u00e4ts-Level zur\u00fcck.",
      "params": [
        {
          "name": "complexity",
          "type": "string",
          "description": "micro|mid|heavy",
          "required": true
        }
      ],
      "command": [
        "python3",
        "-c",
        "import sys; sys.path.insert(0,'/Users/jeremy/dev/stealth-cost'); from stealth_cost import get_optimizer; print(get_optimizer().best_model_for_complexity(sys.argv[1] if len(sys.argv)>1 else 'mid'))",
        "{complexity}"
      ]
    },
    {
      "name": "sota-stats",
      "description": "Zeigt kombinierte Stats aller 5 Kostenspar-Strategien.",
      "params": [],
      "command": [
        "python3",
        "-c",
        "import sys; sys.path.insert(0,'/Users/jeremy/dev/stealth-cost'); from stealth_cost import get_optimizer; import json; print(json.dumps(get_optimizer().stats(), indent=2))"
      ]
    },
    {
      "name": "config-get",
      "description": "Gibt Konfigurationswert aus config.yaml zur\u00fcck.",
      "params": [
        {
          "name": "section",
          "type": "string",
          "description": "Section: cache|compressor|batch|routing|output_limiter",
          "required": true
        }
      ],
      "command": [
        "python3",
        "-c",
        "import sys; sys.path.insert(0,'/Users/jeremy/dev/stealth-config'); from stealth_config import get_config; print(get_config().get(sys.argv[1] if len(sys.argv)>1 else ''))",
        "{section}"
      ]
    },
    {
      "name": "axiom-set-active-adapter",
      "description": "Aktiviert einen bestimmten Adapter fuer nachfolgende Inferenzen.",
      "params": [
        {
          "name": "--adapter-id",
          "type": "string",
          "required": true
        }
      ],
      "command": [
        "python3",
        "-c",
        "import sys; sys.path.insert(0,'/Users/jeremy/dev/stealth-axiom'); from stealth_axiom.adapter_registry import AdapterRegistry; r=AdapterRegistry(); r.activate(sys.argv[1]); print(f'adapter {sys.argv[1]} active')",
        "{--adapter-id}"
      ]
    },
    {
      "name": "axiom-analyze-with-adapter",
      "description": "Fuehrt eine tiefe Analyse mit dem besten LoRA-Adapter durch.",
      "params": [
        {
          "name": "--task",
          "type": "string",
          "required": true
        },
        {
          "name": "--prompt",
          "type": "string",
          "required": true
        }
      ],
      "command": [
        "python3",
        "-c",
        "import sys; sys.path.insert(0,'/Users/jeremy/dev/stealth-axiom'); from stealth_axiom.adapter_registry import AdapterRegistry; r=AdapterRegistry(); a=r.best_for_task(sys.argv[1]); print(f'best adapter: {a.get(\\\"adapter_id\\\",\\\"none\\\") if a else \\\"none\\\"}')",
        "{--task}",
        "{--prompt}"
      ]
    }
  ],
